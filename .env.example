# 共享默认的 OpenAI-compatible LLM 配置。
# 例如：
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_BASE_URL=
LLM_API_KEY=

# 主 Agent 模型。用于需求理解、推荐分析和用户沟通。
MAIN_AGENT_MODEL=gpt-4o

# 研究 Agent 模型。用于 Tavily 搜索后的信息筛选与结构化提取。
RESEARCH_AGENT_MODEL=gpt-4o-mini

# 可选：主 Agent 专属 endpoint / key。若留空，则回退到共享默认配置。
MAIN_AGENT_BASE_URL=
MAIN_AGENT_API_KEY=

# 可选：研究 Agent 专属 endpoint / key。若留空，则回退到共享默认配置。
RESEARCH_AGENT_BASE_URL=
RESEARCH_AGENT_API_KEY=

# Tavily 搜索工具 key。
TAVILY_API_KEY=
